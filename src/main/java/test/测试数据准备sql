-- ========================================
-- data_demo_002 完整测试数据初始化脚本
-- 数据库类型：PostgreSQL
-- 说明：清空所有数据并重新初始化基础数据
-- ========================================

-- 1. 禁用触发器（避免外键约束问题）
SET session_replication_role = 'replica';

-- 2. 清空所有相关表
TRUNCATE TABLE sys_user_role RESTART IDENTITY CASCADE;
TRUNCATE TABLE sys_role_permission RESTART IDENTITY CASCADE;
TRUNCATE TABLE sys_user RESTART IDENTITY CASCADE;
TRUNCATE TABLE sys_role RESTART IDENTITY CASCADE;
TRUNCATE TABLE sys_permission RESTART IDENTITY CASCADE;
TRUNCATE TABLE sys_organization RESTART IDENTITY CASCADE;
TRUNCATE TABLE sys_department RESTART IDENTITY CASCADE;

-- 3. 恢复触发器
SET session_replication_role = 'origin';

